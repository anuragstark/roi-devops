# Production Environment Variables
# Copy this file to /home/ubuntu/app/.env on your EC2 instance

# Node Environment
NODE_ENV=production

# Backend Port
PORT=5000

# Database Configuration (MySQL)
DATABASE_URL=mysql://roi_user:CHANGE_THIS_PASSWORD@mysql:3306/roi_platform

# MySQL Root Password
MYSQL_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD
MYSQL_DATABASE=roi_platform
MYSQL_USER=roi_user
MYSQL_PASSWORD=CHANGE_THIS_PASSWORD

# JWT Secrets (Generate strong random strings!)
JWT_ACCESS_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_TO_DIFFERENT_64_CHAR_STRING
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Admin Seed Credentials
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# User Seed Credentials (optional)
SEED_USER_EMAIL=user@yourdomain.com
SEED_USER_PASSWORD=CHANGE_THIS_PASSWORD

# Frontend API URL (Update with your EC2 public IP)
# VITE_API_URL=http://YOUR_EC2_PUBLIC_IP:5000/api
VITE_API_URL=http://52.71.21.51:5000/api

# SMTP Configuration (Optional - for email features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Payment Gateway (Optional - configure when needed)
PAYMENT_GATEWAY_KEY=
PAYMENT_GATEWAY_SECRET=

# Instructions:
# 1. SSH into your EC2: ssh -i key.pem ubuntu@YOUR_IP
# 2. Create .env file: nano /home/ubuntu/app/.env
# 3. Copy content from this file and update all CHANGE_THIS values
# 4. Save and exit (Ctrl+X, Y, Enter)
# 5. Run deployment: cd /home/ubuntu/app && bash infra/scripts/deploy.sh
