# AWS Configuration
aws_region    = "us-east-1"
instance_type = "t3.micro"

# SSH Key Pair (create this in AWS EC2 console first)
key_pair_name = "roi-platform-key"

# Environment
environment = "production"

# GitHub Repository
github_repo   = "https://github.com/your-username/roi"
github_branch = "main"

# Instructions:
# 1. Copy this file to terraform.tfvars
# 2. Update the values above
# 3. Create SSH key pair in AWS EC2 console
# 4. Run: terraform init
# 5. Run: terraform plan
# 6. Run: terraform apply
