# Local .terraform directories
**/.terraform/*
.terraform/
local_plugins/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Environment variables
.env
.env.*
!.env.example

# Ignore private docs
docs/

# OS generated files
.DS_Store
.DS_Store?
.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.dbs
Thumbs.db

# Local development files
docker-compose.dev.yml
